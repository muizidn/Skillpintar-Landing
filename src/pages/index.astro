---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead
			title="SkillPintar | Platform LMS & Sertifikasi Online Whitelabel"
			description="Bangun platform pembelajaran online Anda sendiri dengan SkillPintar. LMS canggih dengan fitur sertifikasi dan whitelabel untuk bisnis dan institusi."
		/>
		<style>
			:root {
				--page-bg: #ffffff;
				--panel: #f9fafb;
				--panel-strong: #f3f4f6;
				--line: rgba(0, 0, 0, 0.05);
				--muted: #4b5563;
				--text: #111827;
				--primary: #16a34a;
				--primary-light: #4ade80;
				--primary-dark: #15803d;
				--ink: #ffffff;
				--accent: #16a34a;
			}

			* {
				box-sizing: border-box;
			}

			body {
				min-height: 100vh;
				background: 
					radial-gradient(circle at 16% 6%, rgba(22, 163, 74, 0.05), transparent 31rem),
					radial-gradient(circle at 86% 16%, rgba(74, 222, 128, 0.05), transparent 28rem),
					var(--page-bg);
				color: var(--text);
				font-family:
					'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
				line-height: 1.5;
				margin: 0;
			}

			a {
				color: inherit;
				transition: color 0.2s ease;
			}

			main {
				max-width: none;
				padding: 0;
				overflow: hidden;
			}

			.site-shell {
				width: min(1180px, calc(100% - 40px));
				margin: 0 auto;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 46px;
				padding: 0 24px;
				border: 1px solid var(--line);
				border-radius: 10px;
				color: var(--text);
				font-size: 0.95rem;
				font-weight: 600;
				text-decoration: none;
				white-space: nowrap;
				transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.btn-primary {
				background: var(--primary);
				color: var(--ink);
				border-color: transparent;
				box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
			}

			.btn-primary:hover {
				background: var(--primary-dark);
				transform: translateY(-1px);
				box-shadow: 0 12px 30px -5px rgba(37, 99, 235, 0.5);
			}

			.btn-secondary {
				background: #ffffff;
			}

			.btn-secondary:hover {
				background: var(--panel);
				border-color: var(--primary-light);
			}

			.hero {
				position: relative;
				padding: 100px 0 80px;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: 1.1fr 0.9fr;
				align-items: center;
				gap: 64px;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				min-height: 32px;
				padding: 0 16px;
				border: 1px solid rgba(37, 99, 235, 0.15);
				border-radius: 999px;
				background: rgba(37, 99, 235, 0.08);
				color: var(--primary);
				font-size: 0.85rem;
				font-weight: 700;
				margin-bottom: 24px;
			}

			h1 {
				margin: 0 0 24px;
				color: var(--text);
				font-size: clamp(3rem, 6vw, 4.5rem);
				line-height: 1.1;
				letter-spacing: -0.03em;
				font-weight: 900;
			}

			h1 span {
				color: var(--primary);
				display: block;
			}

			.lede {
				max-width: 580px;
				margin: 0;
				color: var(--muted);
				font-size: clamp(1.1rem, 1.5vw, 1.25rem);
				line-height: 1.6;
			}

			.hero-actions {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 16px;
				margin: 40px 0 32px;
			}

			.trust-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				color: var(--muted);
				font-size: 0.9rem;
				font-weight: 500;
			}

			.trust-pill {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 8px 16px;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: #ffffff;
			}

			.trust-pill::before {
				content: "✓";
				color: var(--primary);
				font-weight: 900;
			}

			.product-preview {
				position: relative;
				padding: 12px;
				border: 1px solid var(--line);
				border-radius: 24px;
				background: #ffffff;
				box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.1);
			}

			.product-window {
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 16px;
				background: #ffffff;
			}

			.window-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 12px 20px;
				border-bottom: 1px solid var(--line);
				background: var(--panel);
				color: var(--muted);
				font-size: 0.85rem;
				font-weight: 500;
			}

			.dots {
				display: flex;
				gap: 6px;
			}

			.dots span {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: #cbd5e1;
			}

			.chat-interface {
				padding: 24px;
				background: #ffffff;
				min-height: 400px;
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.chat-bubble {
				max-width: 80%;
				padding: 14px 18px;
				border-radius: 18px;
				font-size: 0.95rem;
				line-height: 1.5;
			}

			.bubble-ai {
				align-self: flex-start;
				background: var(--panel);
				color: var(--text);
				border-bottom-left-radius: 4px;
				border: 1px solid var(--line);
			}

			.bubble-user {
				align-self: flex-end;
				background: var(--primary);
				color: var(--ink);
				border-bottom-right-radius: 4px;
			}

			.whitelabel-tag {
				position: absolute;
				top: -20px;
				right: 30px;
				background: #0f172a;
				color: #ffffff;
				padding: 8px 20px;
				border-radius: 12px;
				font-size: 0.85rem;
				font-weight: 700;
				box-shadow: 0 10px 20px rgba(0,0,0,0.2);
			}

			.section {
				padding: 100px 0;
				border-top: 1px solid var(--line);
			}

			.section-header {
				text-align: center;
				max-width: 800px;
				margin: 0 auto 64px;
			}

			.kicker {
				display: block;
				color: var(--primary);
				font-weight: 800;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 16px;
			}

			.section h2 {
				font-size: clamp(2.2rem, 4vw, 3.2rem);
				font-weight: 900;
				line-height: 1.1;
				margin: 0 0 20px;
				letter-spacing: -0.02em;
			}

			.feature-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 32px;
			}

			.feature-card {
				padding: 40px;
				border-radius: 20px;
				border: 1px solid var(--line);
				background: #ffffff;
				transition: all 0.3s ease;
			}

			.feature-card:hover {
				border-color: var(--primary-light);
				box-shadow: 0 20px 40px -10px rgba(37, 99, 235, 0.1);
				transform: translateY(-4px);
			}

			.icon-box {
				width: 54px;
				height: 54px;
				border-radius: 12px;
				background: rgba(37, 99, 235, 0.1);
				color: var(--primary);
				display: grid;
				place-items: center;
				font-size: 1.5rem;
				margin-bottom: 24px;
			}

			.feature-card h3 {
				font-size: 1.4rem;
				font-weight: 800;
				margin: 0 0 16px;
			}

			.feature-card p {
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}

			.workflow {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 24px;
			}

			.step {
				position: relative;
			}

			.step-num {
				font-size: 4rem;
				font-weight: 900;
				color: rgba(37, 99, 235, 0.08);
				line-height: 1;
				margin-bottom: -20px;
			}

			.step h3 {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 12px;
				position: relative;
			}

			.step p {
				color: var(--muted);
				font-size: 0.95rem;
				margin: 0;
			}

			.cta-section {
				padding: 100px 0;
				background: var(--text);
				color: #ffffff;
				border-radius: 40px;
				margin: 0 20px 40px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}

			.cta-section::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: radial-gradient(circle at 50% 50%, rgba(22, 163, 74, 0.2), transparent);
				pointer-events: none;
			}

			.cta-section h2 {
				font-size: clamp(2.5rem, 5vw, 4rem);
				font-weight: 900;
				margin-bottom: 24px;
			}

			@media (max-width: 980px) {
				.hero-grid {
					grid-template-columns: 1fr;
					text-align: center;
				}
				.lede {
					margin: 0 auto;
				}
				.hero-actions {
					justify-content: center;
				}
				.trust-row {
					justify-content: center;
				}
				.feature-grid {
					grid-template-columns: 1fr;
				}
				.workflow {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 640px) {
				.workflow {
					grid-template-columns: 1fr;
				}
				.cta-section {
					margin: 0 12px 24px;
					padding: 60px 20px;
				}
			}

			.testimonials-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}

			.testimonial-card {
				padding: 32px;
				border-radius: 20px;
				background: #ffffff;
				border: 1px solid var(--line);
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.quote {
				font-size: 1.1rem;
				line-height: 1.6;
				color: var(--text);
				font-style: italic;
				margin: 0;
			}

			.author {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-top: auto;
			}

			.author-info strong {
				display: block;
				font-size: 0.95rem;
				color: var(--text);
			}

			.author-info span {
				font-size: 0.85rem;
				color: var(--muted);
			}

			@media (max-width: 980px) {
				.testimonials-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="site-shell hero-grid">
					<div>
						<span class="badge">Verified Skill Testing Platform</span>
						<h1>Prove Your Skills, <span>Boost Your Career</span></h1>
						<p class="lede">
							Get certified in your expert fields, showcase your verified skills to employers, and land your dream job with SkillPintar.
						</p>
						<div class="hero-actions">
							<a class="btn btn-primary" href="/tests">Mulai Tes Sekarang</a>
							<a class="btn btn-secondary" href="#layanan">Pelajari Lebih Lanjut</a>
						</div>
						<div class="trust-row">
							<span class="trust-pill">Verified Certifications</span>
							<span class="trust-pill">Trusted by Employers</span>
							<span class="trust-pill">100% Secure & Fair</span>
						</div>
					</div>

					<div class="product-preview">
						<div class="whitelabel-tag">Your Brand Here</div>
						<div class="product-window">
							<div class="window-bar">
								<div class="dots"><span></span><span></span><span></span></div>
								<span>Skill Assessment Dashboard</span>
							</div>
							<div class="chat-interface">
								<div style="background: #f0fdf4; border: 1px solid #dcfce7; padding: 20px; border-radius: 12px; margin-bottom: 15px;">
									<div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
										<strong style="color: #16a34a;">React.js Senior Assessment</strong>
										<span style="color: #16a34a; font-weight: 800;">85% Done</span>
									</div>
									<div style="width: 100%; height: 8px; background: #dcfce7; border-radius: 4px; overflow: hidden;">
										<div style="width: 85%; height: 100%; background: #16a34a;"></div>
									</div>
								</div>
								<div style="padding: 15px; border: 1px solid #f3f4f6; border-radius: 12px; display: flex; gap: 12px; align-items: center;">
									<div style="width: 40px; height: 40px; background: #f3f4f6; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #16a34a;">JS</div>
									<div>
										<div style="font-weight: 700; font-size: 0.9rem;">JavaScript Fundamentals</div>
										<div style="font-size: 0.8rem; color: #6b7280;">Certified on May 10, 2026</div>
									</div>
									<div style="margin-left: auto; color: #16a34a; font-weight: 900;">✓</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="layanan" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Layanan Kami</span>
						<h2>Solusi LMS & Edukasi Digital Terpercaya</h2>
					</div>
					<div class="feature-grid">
						<a href="/layanan/setup-lms-kustom/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🎓</div>
							<h3>Setup LMS Kustom</h3>
							<p>Bangun platform pembelajaran online dengan fitur lengkap: materi video, kuis, dan manajemen siswa.</p>
						</a>
						<a href="/layanan/ujian-online/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">📝</div>
							<h3>Ujian & Quiz Online</h3>
							<p>Sistem penilaian otomatis untuk ujian sekolah, sertifikasi profesi, atau rekrutmen karyawan.</p>
						</a>
						<a href="/layanan/sertifikasi-digital/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">📜</div>
							<h3>Sertifikasi Digital</h3>
							<p>Generate sertifikat otomatis dengan QR code verifikasi untuk setiap siswa yang lulus kursus.</p>
						</a>
						<a href="/layanan/lms-api-integration/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🔌</div>
							<h3>Integrasi API LMS</h3>
							<p>Hubungkan LMS Anda dengan sistem internal, HRIS, atau aplikasi mobile kustom melalui API kami.</p>
						</a>
						<a href="/layanan/white-label-lms/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🤝</div>
							<h3>White-Label LMS</h3>
							<p>Miliki platform edukasi dengan brand Anda sendiri tanpa jejak SkillPintar. Cocok untuk agensi edukasi.</p>
						</a>
						<a href="/blog" class="feature-card" style="text-decoration: none; border-style: dashed; background: var(--panel);">
							<div class="icon-box">📚</div>
							<h3>Wawasan & Blog</h3>
							<p>Pelajari strategi terbaru seputar e-learning dan pengembangan SDM untuk pertumbuhan bisnis Anda.</p>
						</a>
					</div>
				</div>
			</section>

			<section id="fitur" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Fitur Unggulan</span>
						<h2>Solusi LMS Lengkap untuk Pendidikan Modern</h2>
					</div>
					<div class="feature-grid">
						<div class="feature-card">
							<div class="icon-box">📖</div>
							<h3>Interactive Learning</h3>
							<p>Materi pembelajaran yang mendukung video, kuis interaktif, dan forum diskusi untuk hasil maksimal.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">🏷️</div>
							<h3>Full Whitelabel</h3>
							<p>Gunakan brand, logo, dan domain Anda sendiri. Bangun otoritas pendidikan Anda tanpa hambatan.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">📱</div>
							<h3>Mobile Friendly</h3>
							<p>Siswa dapat belajar di mana saja dan kapan saja melalui browser mobile atau aplikasi khusus.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="cara-kerja" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Proses Kami</span>
						<h2>4 Langkah Menuju Otomatisasi</h2>
					</div>
					<div class="workflow">
						<div class="step">
							<div class="step-num">01</div>
							<h3>Konsultasi</h3>
							<p>Diskusi mengenai kurikulum, jumlah siswa, dan kebutuhan fitur khusus LMS Anda.</p>
						</div>
						<div class="step">
							<div class="step-num">02</div>
							<h3>Setup Konten</h3>
							<p>Migrasi materi pembelajaran, pembuatan kuis, dan pengaturan jalur belajar siswa.</p>
						</div>
						<div class="step">
							<div class="step-num">03</div>
							<h3>Customization</h3>
							<p>Penerapan branding Anda dan integrasi sistem pembayaran atau HRIS.</p>
						</div>
						<div class="step">
							<div class="step-num">04</div>
							<h3>Launch!</h3>
							<p>Platform siap digunakan oleh siswa Anda untuk mulai belajar dan berkembang.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="testimonial" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Testimoni</span>
						<h2>Apa Kata Mereka Tentang SkillPintar</h2>
					</div>
					<div class="testimonials-grid">
						<div class="testimonial-card">
							<p class="quote">"Platform LMS-nya sangat intuitif. Kami berhasil mensertifikasi 500+ karyawan dalam waktu satu bulan dengan sangat efisien."</p>
							<div class="author">
								<div class="author-info">
									<strong>Andi Prasetya</strong>
									<span>HR Director</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Whitelabel LMS dari SkillPintar membantu agensi saya menawarkan solusi edukasi ke sekolah-sekolah dengan brand kami sendiri."</p>
							<div class="author">
								<div class="author-info">
									<strong>Budi Santoso</strong>
									<span>CEO Education Consultant</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Sistem ujian online-nya sangat stabil. Sangat membantu dalam proses seleksi beasiswa yang kami selenggarakan."</p>
							<div class="author">
								<div class="author-info">
									<strong>Citra Lestari</strong>
									<span>Foundation Manager</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="whitelabel" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Peluang Agensi</span>
						<h2>Bangun Bisnis Edukasi SaaS Anda Sendiri</h2>
						<p class="lede" style="margin: 0 auto;">Dengan fitur Whitelabel, Anda bisa menjual kembali layanan LMS ini kepada klien Anda dengan harga dan brand Anda sendiri.</p>
					</div>
					<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
						<div class="product-preview" style="background: var(--panel); display: flex; align-items: center; justify-content: center; min-height: 180px;">
							<img src="/logo.png" alt="Your Logo Here" style="width: 120px; height: 120px; object-fit: contain; border-radius: 12px;" />
						</div>
						<div>
							<ul style="list-style: none; padding: 0; display: grid; gap: 20px;">
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Custom Domain & Dashboard
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Laporan Performa untuk Klien
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Kontrol Penuh Atas Harga Jual
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
