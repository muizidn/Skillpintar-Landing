{
	"compatibility_date": "2026-05-08",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "skillpintar-com",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "skillpintar.com",
			"custom_domain": true
		},
		{
			"pattern": "www.skillpintar.com",
			"custom_domain": true
		}
	]
}